<?xml version="1.0" ?>
<robot name="xMateSR4C" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <material name="black">
    <color rgba="0.0 0.0 0.0 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.0 0.0 0.8 1.0"/>
  </material>
  <material name="green">
    <color rgba="0.0 0.8 0.0 1.0"/>
  </material>
  <material name="grey">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="orange">
    <color rgba="1.0 0.423529411765 0.0392156862745 1.0"/>
  </material>
  <material name="brown">
    <color rgba="0.870588235294 0.811764705882 0.764705882353 1.0"/>
  </material>
  <material name="red">
    <color rgba="0.8 0.0 0.0 1.0"/>
  </material>
  <material name="white">
    <color rgba="1.0 1.0 1.0 1.0"/>
  </material>
  <material name="Beige">
    <color rgba="1.0 0.784 0.5765 1.0"/>
  </material>
  <link name="world"/>
  <joint name="fixed" type="fixed">
    <parent link="world"/>
    <child link="xMateSR4C_base"/>
    <!-- base关节与world固定连接，因此不用修改质量、惯量、质心等参数，不参与动力学计算 -->
  </joint>
  <link name="xMateSR4C_base">
    <visual>
      <geometry>
        <mesh filename="../stl/xMateSR4C_base.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
      <material name="white"/>
    </visual>
    <inertial>
      <!-- 质量参数 -->
      <mass value="3.16699999486378"/>
      <!-- 惯性张量 -->
      <inertia ixx=" 0.058267910813839" ixy="-3.715826953316560e-07" ixz="-1.05949175179955e-06" iyy=" 0.0576103483714700" iyz="-0.00456914016524626" izz=" 0.00607968319952077"/>
      <!-- 质心参数 -->
      <origin rpy="0 0 0" xyz="-0.000072769597 -0.001679187012 0.002986854502"/>
    </inertial>
    <collision>
      <geometry>
        <mesh filename="../stl/xMateSR4C_base.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
    </collision>
  </link>

  <joint name="xmate_joint_1" type="revolute">
    <parent link="xMateSR4C_base"/>
    <child link="xMateSR4C_link1"/>
    <limit effort="300" lower="-3.1416" upper="3.1416" velocity="10"/>
    <axis xyz="0 0 1"/>
    <origin xyz="0 0 0" rpy="0 0 0" />
  </joint>
  <transmission name="tran1">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="xmate_joint_1">
      <hardwareInterface>EffortJointInterface</hardwareInterface>
    </joint>
    <actuator name="motor1">
      <hardwareInterface>EffortJointInterface</hardwareInterface>
      <mechanicalReduction>100</mechanicalReduction>
    </actuator>
  </transmission>

  <link name="xMateSR4C_link1">
